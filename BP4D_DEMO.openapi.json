  "components": {
    "schemas": {
      "operators": {
        "type": "object",
        "properties": {
          "operators": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/operatorId"
            }
          }
        },
        "title": "operator list",
        "required": [
          "operators"
        ]
      },
      "operatorId": {
        "type": "string",
        "minLength": 2,
        "maxLength": 30,
        "pattern": "^\\w+$",
        "description": "operator ID"
      },
      "operatorDetails": {
        "type": "object",
        "properties": {
          "operatorId": {
            "description": "operator ID",
            "$ref": "#/components/schemas/operatorId"
          },
          "employeeId": {
            "type": "string",
            "description": "employee ID",
            "title": "",
            "maxLength": 11,
            "nullable": true
          },
          "operatorDescription": {
            "type": "string",
            "description": "operator definition description",
            "title": "",
            "maxLength": 30,
            "nullable": true
          },
          "operatorClass": {
            "type": "string",
            "description": "operator class",
            "title": "",
            "maxLength": 30,
            "nullable": true
          },
          "rowSecurityClass": {
            "type": "string",
            "description": "row security class",
            "title": "",
            "maxLength": 30,
            "nullable": true
          },
          "processProfileClass": {
            "type": "string",
            "description": "process profile class",
            "title": "",
            "maxLength": 30,
            "nullable": true
          },
          "failedLogins": {
            "type": "number",
            "description": "failed logins (count)"
          },
          "isLocked": {
            "type": "boolean",
            "description": "account is locked"
          },
          "lastSignonDatetime": {
            "type": "string",
            "title": "",
            "description": "last signon datetime"
          }
        },
        "required": [
          "operatorId",
          "employeeId",
          "operatorDescription",
          "operatorClass",
          "rowSecurityClass",
          "processProfileClass",
          "isLocked",
          "lastSignonDatetime",
          "failedLogins"
        ]
      },
      "operatorRoles": {
        "type": "object",
        "properties": {
          "operatorRoles": {
            "type": "object",
            "properties": {
              "operatorId": {
                "description": "operator ID",
                "$ref": "#/components/schemas/operatorId"
              },
              "roles": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/roleName"
                }
              }
            },
            "required": [
              "operatorId",
              "roles"
            ]
          }
        },
        "required": [
          "operatorRoles"
        ]
      },
      "filters": {
        "type": "object",
        "properties": {
          "filters": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "fieldname": {
                  "type": "string",
                  "description": "field name",
                  "maxLength": 30
                },
                "fieldvalue": {
                  "type": "string",
                  "description": "field value",
                  "maxLength": 30
                }
              },
              "required": [
                "fieldname",
                "fieldvalue"
              ]
            }
          }
        },
        "required": [
          "filters"
        ]
      },
      "roles": {
        "type": "object",
        "properties": {
          "roles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/roleName"
            }
          }
        },
        "title": "role list"
      },
      "roleName": {
        "type": "string",
        "description": "role name",
        "minLength": 2,
        "maxLength": 30,
        "pattern": "^[^';:&\\(\\)\\[\\]\\/\\\\\\<\\>]+$"
      },
      "roleDetails": {
        "type": "object",
        "properties": {
          "roleName": {
            "description": "role name",
            "$ref": "#/components/schemas/roleName"
          },
          "version": {
            "type": "integer",
            "description": "version number"
          },
          "roleType": {
            "type": "string",
            "description": "role type",
            "title": "",
            "minLength": 1,
            "maxLength": 1
          },
          "roleDescription": {
            "type": "string",
            "description": "role description",
            "title": "",
            "maxLength": 30
          },
          "roleStatus": {
            "type": "string",
            "description": "role status",
            "title": "",
            "minLength": 1,
            "maxLength": 1
          },
          "isRoleQueryEnabled": {
            "type": "boolean",
            "description": "role is query enabled",
            "default": false
          },
          "roleQueryName": {
            "type": "string",
            "description": "role query name",
            "title": "",
            "maxLength": 30
          },
          "lastUpdatedDatetime": {
            "type": "string",
            "title": "",
            "description": "last updated datetime"
          }
        },
        "required": [
          "roleName",
          "version",
          "roleType",
          "roleDescription",
          "roleStatus",
          "isRoleQueryEnabled",
          "roleQueryName",
          "lastUpdatedDatetime"
        ]
      },
      "classId": {
        "type": "string",
        "description": "class ID",
        "minLength": 2,
        "maxLength": 30,
        "pattern": "^[^';:&\\(\\)\\[\\]\\/\\\\\\<\\> ]+$"
      },
      "permissionsList": {
        "type": "object",
        "properties": {
          "rolePermissions": {
            "type": "object",
            "properties": {
              "roleName": {
                "description": "role name",
                "$ref": "#/components/schemas/roleName"
              },
              "permissions": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/classId"
                }
              }
            },
            "required": [
              "roleName",
              "permissions"
            ]
          }
        },
        "title": "permissions list",
        "required": [
          "rolePermissions"
        ]
      },
      "operatorsDoc": {
        "type": "object",
        "properties": {
          "operatorsDoc": {
            "type": "object",
            "properties": {
              "operators": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/operatorId"
                }
              }
            },
            "required": [
              "operators"
            ]
          }
        },
        "required": [
          "operatorsDoc"
        ]
      }
    },
